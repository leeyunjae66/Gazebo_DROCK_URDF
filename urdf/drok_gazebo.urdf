        <param name="max">30.0</param>
      </command_interface>
      <state_interface name="position" />
      <state_interface name="velocity" />
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="simple_tracked_vehicle" filename="libSimpleTrackedVehiclePlugin.so">
      <body>base_link</body>

      <left_track>left_track</left_track>
      <right_track>right_track</right_track>

      <left_flipper>FLF</left_flipper>
      <left_flipper>BLF</left_flipper>

      <right_flipper>FRF</right_flipper>
      <right_flipper>BRF</right_flipper>

      <robot_namespace>/drok_gazebo</robot_namespace>

      <tracks_separation>0.3672</tracks_separation>

      <steering_efficiency>0.75</steering_efficiency>

      <max_linear_speed>2.0</max_linear_speed>
      <max_angular_speed>6.0</max_angular_speed>

      <track_mu>1.0</track_mu>
      <track_mu2>0.5</track_mu2>

      <collide_without_contact_bitmask>1</collide_without_contact_bitmask>
    </plugin>

    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>/home/ams7725/yunjae/ros2_ws/install/gazebo_control/share/gazebo_control/config/controllers.yaml</parameters>
    </plugin>
